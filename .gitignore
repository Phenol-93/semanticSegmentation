# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# IDE and OS files
.idea/
.vscode/
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
*.tmp
*.bak

# Local input images
input_images/*
!input_images/.gitkeep

# Downloaded model files and generated model metadata
checkpoints/*
!checkpoints/.gitkeep

# Pipeline outputs
outputs/*
!outputs/.gitkeep
!outputs/cityscapes_vis/
!outputs/cityscapes_vis/.gitkeep
!outputs/cityscapes_pred/
!outputs/cityscapes_pred/.gitkeep
!outputs/project_pred/
!outputs/project_pred/.gitkeep
!outputs/project_vis/
!outputs/project_vis/.gitkeep
!outputs/project_overlay/
!outputs/project_overlay/.gitkeep
!outputs/reports/
!outputs/reports/.gitkeep

# Large model artifacts if generated outside checkpoints
*.pth
*.pt
*.onnx

# Local notebooks and experiment scratch files
.ipynb_checkpoints/
